<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://schemas.xmlsoap.org/wsdl/"
             xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
             xmlns:tns="http://example.com/headerbody"
             xmlns:xsd="http://www.w3.org/2001/XMLSchema"
             targetNamespace="http://example.com/headerbody"
             name="HeaderBodyService">

  <types>
    <xsd:schema targetNamespace="http://example.com/headerbody">
      <xsd:element name="GetItem">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="itemId" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="GetItemResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="result" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="AuthToken">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="token" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
    </xsd:schema>
  </types>

  <message name="GetItemSoapIn">
    <part name="parameters" element="tns:GetItem"/>
    <part name="authToken" element="tns:AuthToken"/>
  </message>
  <message name="GetItemSoapOut">
    <part name="parameters" element="tns:GetItemResponse"/>
  </message>

  <portType name="HeaderBodyPortType">
    <operation name="GetItem">
      <input message="tns:GetItemSoapIn"/>
      <output message="tns:GetItemSoapOut"/>
    </operation>
  </portType>

  <binding name="HeaderBodyBinding" type="tns:HeaderBodyPortType">
    <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
    <operation name="GetItem">
      <soap:operation soapAction="http://example.com/headerbody/GetItem"/>
      <input>
        <soap:body parts="parameters" use="literal"/>
        <soap:header message="tns:GetItemSoapIn" part="authToken" use="literal"/>
      </input>
      <output>
        <soap:body use="literal"/>
      </output>
    </operation>
  </binding>

  <service name="HeaderBodyService">
    <port name="HeaderBodyPort" binding="tns:HeaderBodyBinding">
      <soap:address location="http://example.com/headerbody/service"/>
    </port>
  </service>
</definitions>
